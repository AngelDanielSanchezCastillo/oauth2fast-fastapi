# Database Configuration
AUTH_DB__USERNAME=your_db_user
AUTH_DB__PASSWORD=your_db_password
AUTH_DB__HOSTNAME=localhost
AUTH_DB__NAME=your_database_name
AUTH_DB__PORT=5432

# JWT Configuration (REQUIRED)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Mail Server Configuration
AUTH_MAIL_SERVER__USERNAME=your-email@example.com
AUTH_MAIL_SERVER__PASSWORD=your-email-password
AUTH_MAIL_SERVER__SERVER=smtp.gmail.com
AUTH_MAIL_SERVER__PORT=587
AUTH_MAIL_SERVER__FROM_DIRECTION=noreply@example.com
AUTH_MAIL_SERVER__FROM_NAME=Your App Name
AUTH_MAIL_SERVER__STARTTLS=true
AUTH_MAIL_SERVER__SSL_TLS=false

# Application Settings
PROJECT_NAME=My Awesome App
FRONTEND_URL=https://yourapp.com
AUTH_URL_PREFIX=auth
